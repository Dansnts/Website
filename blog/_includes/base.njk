<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — Dani Faria dos Santos</title>
  <meta name="description" content="{{ description or title }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=14" />
  <link rel="icon" href="/favicon.ico" />
  <style>
    .blog-wrap {
      max-width: 720px;
      margin: 0 auto;
      padding: 2rem 2rem 5rem;
    }

    .prose h1 { font-size: 2rem; font-weight: 700; line-height: 1.2; margin-bottom: 0.4rem; color: var(--text); }
    .prose h2 { font-size: 1.2rem; font-weight: 600; margin: 2.2rem 0 0.6rem; color: var(--text); }
    .prose h3 { font-size: 1rem; font-weight: 600; margin: 1.6rem 0 0.4rem; color: var(--text); }
    .prose p { margin-bottom: 1.1rem; color: var(--muted); line-height: 1.75; }
    .prose ul, .prose ol { padding-left: 1.4rem; margin-bottom: 1.1rem; color: var(--muted); }
    .prose li { margin-bottom: 0.3rem; line-height: 1.7; }
    .prose a { color: var(--accent); }
    .prose a:hover { opacity: 0.75; }
    .prose code {
      font-family: var(--mono);
      font-size: 0.82em;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 0.15em 0.4em;
      border-radius: 4px;
      color: var(--text);
    }
    .prose pre {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.2rem;
      overflow-x: auto;
      margin-bottom: 1.4rem;
    }
    .prose pre code { background: none; border: none; padding: 0; font-size: 0.82rem; }
    .prose blockquote {
      border-left: 2px solid var(--accent);
      padding: 0.1rem 1rem;
      color: var(--muted);
      margin: 1.5rem 0;
    }
    .prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
    .prose img { max-width: 100%; border-radius: 8px; margin: 1rem 0; }

    .post-meta {
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--subtle);
      margin-bottom: 2.5rem;
      display: flex;
      gap: 1rem;
      letter-spacing: 0.05em;
    }

    .blog-header { margin-bottom: 2.5rem; }
    .blog-header h1 { font-size: 2rem; font-weight: 700; color: var(--text); margin-bottom: 0.3rem; }
    .blog-header p { color: var(--muted); font-size: 0.95rem; }

    .post-list { list-style: none; padding: 0; }
    .post-list li { padding: 1.4rem 0; border-bottom: 1px solid var(--border); }
    .post-list li:first-child { border-top: 1px solid var(--border); }
    .post-date {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--subtle);
      letter-spacing: 0.06em;
      margin-bottom: 0.3rem;
    }
    .post-list a { font-size: 1.05rem; font-weight: 600; color: var(--text); text-decoration: none; transition: color var(--t); }
    .post-list a:hover { color: var(--accent); }
    .post-desc { font-size: 0.88rem; color: var(--muted); margin-top: 0.25rem; line-height: 1.6; }
  </style>
</head>
<body>
  <div id="site-header"></div>
  <main>
    <div class="blog-wrap">
      {{ content | safe }}
    </div>
  </main>
  <div id="site-footer"></div>
  <script src="/js/i18n.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
