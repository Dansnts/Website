<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — Dani Faria dos Santos</title>
  <meta name="description" content="{{ description or title }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=14" />
  <link rel="icon" href="/favicon.ico" />
  <style>
    /* ── Blog listing ── */
    .blog-index-wrap { max-width: 760px; margin: 0 auto; padding: 2rem 2rem 5rem; }
    .post-list { list-style: none; padding: 0; margin-top: 1.5rem; }
    .post-list li { padding: 1.4rem 0; border-bottom: 1px solid var(--border); }
    .post-list li:first-child { border-top: 1px solid var(--border); }
    .post-date { font-family: var(--mono); font-size: 0.68rem; color: var(--subtle); letter-spacing: 0.06em; margin-bottom: 0.3rem; }
    .post-list a { font-size: 1.05rem; font-weight: 600; color: var(--text); text-decoration: none; transition: color var(--t); }
    .post-list a:hover { color: var(--accent); }
    .post-desc { font-size: 0.875rem; color: var(--muted); margin-top: 0.25rem; line-height: 1.6; font-weight: 300; }

    /* ── Blog post body (Markdown output inside .project-detail) ── */
    .blog-body { padding-bottom: 5rem; }

    .blog-body h2 {
      font-family: var(--mono);
      font-size: 0.62rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin: 2.5rem 0 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .blog-body h3 {
      font-family: var(--sans);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--subtle);
      margin: 1.75rem 0 0.5rem;
    }
    .blog-body p {
      font-family: var(--sans);
      font-size: 0.875rem;
      font-weight: 300;
      color: var(--subtle);
      line-height: 1.75;
      margin-bottom: 1rem;
    }
    .blog-body ul, .blog-body ol {
      padding-left: 1.4rem;
      margin-bottom: 1rem;
      color: var(--subtle);
    }
    .blog-body li {
      font-family: var(--sans);
      font-size: 0.875rem;
      font-weight: 300;
      line-height: 1.75;
      margin-bottom: 0.25rem;
    }
    .blog-body a { color: var(--accent); }
    .blog-body a:hover { opacity: 0.75; }
    .blog-body strong { color: var(--text); font-weight: 600; }
    .blog-body em { color: var(--subtle); font-style: italic; }
    .blog-body code {
      font-family: var(--mono);
      font-size: 0.8em;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 0.15em 0.4em;
      border-radius: 4px;
      color: var(--accent);
    }
    .blog-body blockquote {
      border-left: 2px solid var(--accent);
      padding: 0.1rem 1rem;
      color: var(--muted);
      margin: 1.5rem 0;
    }
    .blog-body hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
    .blog-body img { max-width: 100%; border-radius: 8px; margin: 1rem 0; }
    .blog-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-family: var(--sans);
      font-size: 0.82rem;
      overflow-x: auto;
      display: block;
    }
    .blog-body thead tr { border-bottom: 1px solid var(--border-hi); }
    .blog-body th {
      font-family: var(--mono);
      font-size: 0.6rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      padding: 0.55rem 1rem;
      text-align: left;
    }
    .blog-body td {
      padding: 0.6rem 1rem;
      color: var(--subtle);
      font-weight: 300;
      line-height: 1.6;
      border-bottom: 1px solid var(--border);
    }
    .blog-body tr:last-child td { border-bottom: none; }
    .blog-body tbody tr:hover td { background: var(--surface); }

    /* ── Code blocks ── */
    .blog-body pre {
      background: #0c0e18;
      border: 1px solid #1e2030;
      border-radius: 0 0 8px 8px;
      border-top: none;
      padding: 1.25rem 1.5rem;
      overflow-x: auto;
      margin-bottom: 1.4rem;
      font-size: 0.8rem;
      line-height: 1.7;
      color: #dce0f0;
    }
    .blog-body pre code {
      font-family: var(--mono);
      font-size: inherit;
      background: transparent;
      border: none;
      padding: 0;
      color: inherit;
    }
    .code-wrap { margin-bottom: 1.4rem; }
    .code-wrap pre { margin-bottom: 0; }
    .code-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #141625;
      border: 1px solid #1e2030;
      border-radius: 8px 8px 0 0;
      padding: 0.45rem 1rem;
    }
    .code-filename {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: var(--muted);
      letter-spacing: 0.04em;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .code-filename::before {
      content: '';
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--border-hi);
    }
    .code-lang {
      font-family: var(--mono);
      font-size: 0.56rem;
      color: var(--border-hi);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .code-copy {
      font-family: var(--mono);
      font-size: 0.58rem;
      color: var(--muted);
      background: transparent;
      border: 1px solid var(--border-mid);
      border-radius: 3px;
      padding: 0.18rem 0.5rem;
      cursor: pointer;
      transition: all var(--t);
      letter-spacing: 0.04em;
    }
    .code-copy:hover { color: var(--subtle); border-color: var(--border-hi); }
  </style>
</head>
<body>
  <div id="site-header"></div>
  <main>
    {{ content | safe }}
  </main>
  <div id="site-footer"></div>
  <script src="/js/i18n.js"></script>
  <script src="/js/main.js"></script>
  <script>
    document.querySelectorAll('.blog-body pre').forEach(pre => {
      const code = pre.querySelector('code');
      const lang = (code && code.className.match(/language-(\w+)/)?.[1]) || '';
      const wrap = document.createElement('div');
      wrap.className = 'code-wrap';
      const header = document.createElement('div');
      header.className = 'code-header';
      header.innerHTML = `<span class="code-filename">${lang || 'code'}</span><span class="code-lang">${lang}</span><button class="code-copy">Copier</button>`;
      pre.parentNode.insertBefore(wrap, pre);
      wrap.appendChild(header);
      wrap.appendChild(pre);
      header.querySelector('.code-copy').addEventListener('click', function() {
        navigator.clipboard.writeText(code ? code.innerText : pre.innerText);
        this.textContent = 'Copié !';
        setTimeout(() => this.textContent = 'Copier', 2000);
      });
    });
  </script>
</body>
</html>
